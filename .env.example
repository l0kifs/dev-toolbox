# For a globally installed tool, copy this to ~/.kitbag/.env and fill in.
# A .env in the current directory overrides it per-project; real env vars beat both.

# Required by `kitbag ai-commit` — MiniMax API key used to generate commit messages.
MINIMAX_API_KEY=

# Required by `kitbag claude-sandbox` — set whichever Claude credential you use.
# (A long-lived token comes from `claude setup-token`.)
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=
